@using System.Drawing
@inject GameState State

<HeadContent>
    <style>
        :root {
            --board-bg: @ColorTranslator.ToHtml(BoardColor);
            --player1: @ColorTranslator.ToHtml(Player1Color);
            --player2: @ColorTranslator.ToHtml(Player2Color);
        }
    </style>
</HeadContent>

<div class="board-shell">
    <div class="board-header">
        <div class="status">@State.StatusMessage</div>
        <button class="restart" @onclick="ResetGame">Restart game</button>
    </div>

    <div class="column-controls">
        @for (var col = 0; col < GameState.Columns; col++)
        {
            <button class="drop-button" @onclick="() => PlayPiece(col)" disabled="@State.GameOver || State.GetLowestEmptyRow(col) < 0">
                ▼
            </button>
        }
    </div>

    <div class="board">
        @for (var row = 0; row < GameState.Rows; row++)
        {
            @for (var col = 0; col < GameState.Columns; col++)
            {
                var index = row * GameState.Columns + col;
                <span class="container" @onclick="() => PlayPiece(col)">
                    <span class="hole @State.GetPieceClass(State.Board[index])"></span>
                </span>
            }
        }
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        State.ResetBoard();
    }

    private void ResetGame()
    {
        State.ResetBoard();
    }

    private void PlayPiece(int column)
    {
        if (State.PlayPiece(column))
        {
            StateHasChanged();
        }
    }

    [Parameter]
    public Color BoardColor { get; set; } = ColorTranslator.FromHtml("#102a54");

    [Parameter]
    public Color Player1Color { get; set; } = ColorTranslator.FromHtml("#f2c14e");

    [Parameter]
    public Color Player2Color { get; set; } = ColorTranslator.FromHtml("#ef476f");
}
